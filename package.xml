<?xml version="1.0"?>
<package format="3">
  <name>compass_msgs</name>
  <version>0.1.1</version>
  <description>
    ROS 2 port of compass_msgs — messages related to compass and azimuth.
    Message definition identical to ctu-vras/compass for compatibility.
  </description>
  <maintainer email="manankharwar@gmail.com">Manan Kharwar</maintainer>
  <license>BSD</license>

  <buildtool_depend>ament_cmake</buildtool_depend>
  <buildtool_depend>rosidl_default_generators</buildtool_depend>

  <depend>std_msgs</depend>
  <depend>rosidl_default_runtime</depend>

  <member_of_group>rosidl_interface_packages</member_of_group>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
